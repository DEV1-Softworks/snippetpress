{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "snippetpress/code-block",
    "version": "1.0.0",
    "title": "SnippetPress Code",
    "category": "text",
    "icon": "editor-code",
    "description": "Display syntax-highlighted code snippets safely.",
    "keywords": ["code", "snippet", "syntax", "highlight", "programming"],
    "supports": {
        "html": false,
        "className": true,
        "align": ["wide", "full"]
    },
    "textdomain": "snippetpress",
    "attributes": {
        "code": {
            "type": "string",
            "default": ""
        },
        "language": {
            "type": "string",
            "default": "plaintext"
        },
        "lineNumbers": {
            "type": "boolean",
            "default": false
        },
        "title": {
            "type": "string",
            "default": ""
        }
    },
    "editorScript": "file:./index.js",
    "style": "snippetpress-style"
}
