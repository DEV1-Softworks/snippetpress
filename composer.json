{
    "name": "dev1-softworks/snippetpress",
    "description": "Safely display syntax-highlighted code snippets in WordPress posts and pages.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "wp-phpunit/wp-phpunit": "^6.0",
        "yoast/phpunit-polyfills": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "SnippetPress\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SnippetPress\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "roots/wordpress-core-installer": true
        }
    }
}
